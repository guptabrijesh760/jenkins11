pipeline { 
    agent { label 'phpdev'  
    }

    options { 
        timeout(time: 60, unit: 'SECONDS') 
    } 

    environment { 
        CONTAINERIMAGE = 'nginx:latest' 
            // Fixed spelling (ngnix → nginx) 
    }

    stages {
        stage("Code Checkout") {
            steps {
                git branch: 'phpdevelopment', url: 'https://github.com/guptabrijesh760/jenkins11.git'
            }
        }

        stage("PHP Code Remove") { 
            steps {
                echo "Removing old PHP files..."
                sh "rm -rf /var/www/html/*"
            }
        }

        stage("PHP Code Deploy") { 
            steps {
                
                sh "cp -r /home/ec2-user/jenkins/phpdevelopment/src/* /var/www/html/"
            }
        }

        stage("Restart Server") {
            steps {
                
                sh 'sudo systemctl restart httpd'
            }
        }
    }
}